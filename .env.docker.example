# Docker Environment Variables
# For Docker Compose deployment when database is on host machine

# Database Configuration
# Use host.docker.internal to access host machine from Docker container (macOS/Windows)
DB_HOST=host.docker.internal
DB_PORT=37719
DB_NAME=growing
DB_USER=your_db_username
DB_PASSWORD=your_db_password

# For Linux: use the actual host IP address or gateway IP
# Find gateway IP with: docker network inspect bridge | grep Gateway
# DB_HOST=172.17.0.1

# JWT Secret (MUST be a strong, random string in production)
# Generate with: openssl rand -base64 64
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Spring Profile (prod = production mode)
# SPRING_PROFILES_ACTIVE=prod  # Already set in docker-compose.yml

# Optional: Java memory settings (already set in docker-compose.yml)
# JAVA_OPTS=-Xms512m -Xmx1024m
